<?xml version="1.0" encoding="utf-8"?>
<!-- Debug-variant manifest overlay: merged on top of src/main/AndroidManifest.xml
     for debug builds only. Attaches the debug-only network security config that
     permits cleartext to the emulator host alias (10.0.2.2), so the local dev
     gateway is reachable without weakening the release manifest. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application android:networkSecurityConfig="@xml/network_security_config" />

</manifest>
