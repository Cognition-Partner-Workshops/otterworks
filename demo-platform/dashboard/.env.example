# Demo Ops Dashboard runtime configuration.
# In-cluster these come from the `demo-ops-dashboard` Secret / ConfigMap.
# NEVER commit real values.

# Passcode compared (constant-time) at /api/auth/login.
DASHBOARD_PASSCODE=

# HMAC secret used to sign the ow_ops_session cookie.
SESSION_SECRET=

# DynamoDB control table + region.
CONTROL_TABLE=otterworks-demo-control
AWS_REGION=us-east-1

# Platform namespace where runner Jobs are created.
PLATFORM_NAMESPACE=otterworks-platform

# Runner image that executes deploy/teardown/inject scripts.
RUNNER_IMAGE=

# K8s Secret (in PLATFORM_NAMESPACE) the runner Job references via env valueFrom.
RUNNER_SECRET_NAME=demo-ops-dashboard

# ServiceAccount for the web pod + runner Jobs (IRSA-bound).
DASHBOARD_SERVICE_ACCOUNT=demo-ops-dashboard

# Ingress host suffix for tenant URLs (t-<id>.<suffix>).
HOST_SUFFIX=demo.otterworks.app

# Optional: session lifetime in seconds (default ~8h).
# SESSION_TTL_SECONDS=28800
