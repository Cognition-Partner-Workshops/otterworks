{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "ReportDb": "Host=localhost;Port=5432;Database=otterworks_reports;Username=otterworks;Password=otterworks_dev"
  },
  "ReportSettings": {
    "AnalyticsServiceUrl": "http://analytics-service:8088",
    "AuditServiceUrl": "http://audit-service:8090",
    "AuthServiceUrl": "http://auth-service:8081",
    "OutputDir": "/tmp/reports",
    "MaxRows": 50000,
    "ConnectionTimeoutMs": 5000,
    "ReadTimeoutMs": 30000
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8091"
      }
    }
  }
}
