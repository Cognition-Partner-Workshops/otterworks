<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>{"timestamp":"%d{ISO8601}","level":"%level","service":"notification-service","logger":"%logger","message":"%msg"}%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDOUT" />
    </root>

    <logger name="com.otterworks" level="DEBUG" />
    <logger name="io.ktor" level="INFO" />
</configuration>
