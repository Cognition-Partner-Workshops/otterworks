{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Aws": {
    "Region": "us-east-1",
    "S3Bucket": "otterworks-files",
    "DynamoDbTable": "otterworks-file-metadata",
    "DynamoDbFoldersTable": "otterworks-folders",
    "DynamoDbVersionsTable": "otterworks-file-versions",
    "DynamoDbSharesTable": "otterworks-file-shares"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://+:8082"
      }
    }
  }
}
