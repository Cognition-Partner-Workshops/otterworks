{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Aws": {
    "Region": "us-east-1",
    "S3Bucket": "otterworks-gateway-assets",
    "SnsTopicArn": "",
    "SqsQueueUrl": ""
  },
  "Gateway": {
    "RateLimitRequestsPerSecond": 100,
    "CorsAllowedOrigins": "http://localhost:3000,http://localhost:4200",
    "CorsAllowedMethods": "GET,POST,PUT,PATCH,DELETE,OPTIONS",
    "CorsAllowedHeaders": "Accept,Authorization,Content-Type,X-Request-ID",
    "CorsMaxAgeSeconds": 300,
    "ShutdownTimeoutSeconds": 30,
    "CircuitBreakerMaxRequests": 5,
    "CircuitBreakerIntervalSeconds": 60,
    "CircuitBreakerTimeoutSeconds": 30,
    "CircuitBreakerFailureRatio": 0.6
  },
  "ServiceRoutes": {
    "Auth": "http://auth-service:8081",
    "File": "http://file-service:8082",
    "Document": "http://document-service:8083",
    "Collab": "http://collab-service:8084",
    "Notification": "http://notification-service:8086",
    "Search": "http://search-service:8087",
    "Analytics": "http://analytics-service:8088",
    "Admin": "http://admin-service:8089",
    "Audit": "http://audit-service:8090",
    "Report": "http://report-service:8091"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://+:8080"
      }
    }
  }
}
