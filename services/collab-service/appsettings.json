{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Redis": {
    "Host": "localhost",
    "Port": 6379,
    "KeyPrefix": "collab:"
  },
  "Jwt": {
    "Secret": "otterworks-dev-secret",
    "Issuer": "otterworks-auth-service"
  },
  "Persistence": {
    "IntervalMs": 30000,
    "SnapshotIntervalMs": 300000,
    "DocumentTtlSeconds": 86400,
    "SnapshotTtlSeconds": 604800,
    "MaxSnapshotsPerDocument": 50
  },
  "Cors": {
    "Origins": "http://localhost:3000,http://localhost:4200"
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=otterworks;Username=otterworks;Password=otterworks"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://+:8084"
      }
    }
  }
}
