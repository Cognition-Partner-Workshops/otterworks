<UserControl x:Class="OtterWorks.Desktop.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Border Background="White" CornerRadius="10" Padding="32" Width="380"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                BorderBrush="#E5E7EB" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#1F000000" BlurRadius="18" ShadowDepth="2" />
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="Sign in" FontSize="24" FontWeight="Bold" Foreground="#111827" />
                <TextBlock Text="Welcome back to OtterWorks." Foreground="{StaticResource MutedBrush}" Margin="0,4,0,20" />

                <TextBlock Text="Email" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,6" FontSize="14" />

                <TextBlock Text="Password" FontWeight="SemiBold" Margin="0,14,0,4" />
                <PasswordBox x:Name="PasswordInput" Padding="8,6" FontSize="14"
                             PasswordChanged="PasswordInput_PasswordChanged" />

                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"
                           TextWrapping="Wrap" Margin="0,14,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}" />

                <Button Content="Sign in" Style="{StaticResource PrimaryButton}"
                        Command="{Binding LoginCommand}" Margin="0,20,0,0" IsDefault="True" />

                <ProgressBar IsIndeterminate="True" Height="3" Margin="0,10,0,0" BorderThickness="0"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                    <TextBlock Text="No account?" Foreground="{StaticResource MutedBrush}" />
                    <Button Content="Create one" Command="{Binding GoToRegisterCommand}"
                            Background="Transparent" BorderThickness="0" Foreground="{StaticResource AccentBrush}"
                            Cursor="Hand" Margin="6,0,0,0" Padding="0" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
