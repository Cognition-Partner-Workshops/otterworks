<Window x:Class="OtterWorks.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OtterWorks Desktop" Height="640" Width="960"
        WindowStartupLocation="CenterScreen" Background="#F3F4F6">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource AccentBrush}" Padding="18,12">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="OtterWorks" Foreground="White" FontSize="20" FontWeight="Bold" />
                    <TextBlock Text="Desktop" Foreground="#DCE6FF" FontSize="20" Margin="6,0,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0">
                        <Run Text="Signed in as " />
                        <Run Text="{Binding CurrentUserName, Mode=OneWay}" FontWeight="SemiBold" />
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <ContentControl Content="{Binding CurrentViewModel}" />
    </DockPanel>
</Window>
