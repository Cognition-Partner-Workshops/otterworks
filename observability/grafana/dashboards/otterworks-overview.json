{
  "dashboard": {
    "title": "OtterWorks Overview",
    "uid": "otterworks-overview",
    "timezone": "utc",
    "panels": [
      {
        "title": "Service Health",
        "type": "stat",
        "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "up{job=~\".*-service|api-gateway\"}",
            "legendFormat": "{{ job }}"
          }
        ]
      },
      {
        "title": "HTTP Request Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
        "targets": [
          {
            "expr": "rate(http_requests_total[5m])",
            "legendFormat": "{{ job }} - {{ status }}"
          }
        ]
      },
      {
        "title": "HTTP Latency P99",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
        "targets": [
          {
            "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "{{ job }}"
          }
        ]
      },
      {
        "title": "Active WebSocket Connections",
        "type": "gauge",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 12 },
        "targets": [
          {
            "expr": "collab_active_connections",
            "legendFormat": "connections"
          }
        ]
      },
      {
        "title": "Documents Created (24h)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 12 },
        "targets": [
          {
            "expr": "increase(documents_created_total[24h])",
            "legendFormat": "documents"
          }
        ]
      },
      {
        "title": "Files Uploaded (24h)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 12 },
        "targets": [
          {
            "expr": "increase(files_uploaded_total[24h])",
            "legendFormat": "files"
          }
        ]
      },
      {
        "title": "Notifications Sent (24h)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 12 },
        "targets": [
          {
            "expr": "increase(notifications_sent_total[24h])",
            "legendFormat": "notifications"
          }
        ]
      }
    ],
    "time": { "from": "now-6h", "to": "now" },
    "refresh": "30s"
  }
}
