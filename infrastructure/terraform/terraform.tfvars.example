# OtterWorks Infrastructure - Example Variable Values
# Copy this file to terraform.tfvars and customize for your environment.

# AWS region for all resources
aws_region = "us-east-1"

# Environment name (dev, staging, prod)
environment = "dev"

# EKS cluster name from platform-engineering-shared-services
eks_cluster_name = "workshop-dev"

# Kubernetes namespace for OtterWorks
namespace = "decomposition-dev"

# REQUIRED: RDS PostgreSQL master password (no default — must be set)
db_password = "your-secure-password-here"

# REQUIRED: OIDC provider ARN from the EKS cluster (no default — must be set)
# Find with: aws eks describe-cluster --name workshop-dev --query "cluster.identity.oidc.issuer"
oidc_provider_arn = "arn:aws:iam::oidc-provider/oidc.eks.us-east-1.amazonaws.com/id/EXAMPLE"

# CloudWatch log retention in days
log_retention_days = 30
