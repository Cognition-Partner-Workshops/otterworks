# OtterWorks Infrastructure - Example Variable Values
# Copy this file to terraform.tfvars and customize for your environment.
#
# Prerequisites: Platform layer must be applied first (platform/terraform)
# which provisions VPC, EKS, and ECR. This layer reads platform outputs
# via terraform_remote_state.

# AWS region for all resources
aws_region = "us-east-1"

# Environment name (dev, staging, prod)
environment = "dev"

# Kubernetes namespace for OtterWorks services
namespace = "otterworks"

# REQUIRED: RDS PostgreSQL master password (no default — must be set)
db_password = "your-secure-password-here"

# CloudWatch log retention in days
log_retention_days = 30
