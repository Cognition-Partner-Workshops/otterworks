# OtterWorks ETL — Required Environment Variables
# Copy this file to .env and fill in the values.
# The run.sh script sources /opt/etl/.env automatically.

# AWS credentials (use IAM roles in production instead of static keys)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# PostgreSQL credentials (used by analytics_daily.py, user_activity_daily.py)
ETL_DB_USER=
ETL_DB_PASSWORD=

# MeiliSearch API key (used by search_reindex_weekly.py)
MEILISEARCH_API_KEY=
